# Synthetic Panel Frontend - Environment Variables
# Copy this file to .env and fill in your values

# API URL
VITE_API_URL=http://localhost:8003

# WebSocket URL (without /ws prefix)
VITE_WS_URL=ws://localhost:8003

# Allowed parent origins for iframe PostMessage
VITE_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002

# Debug mode
VITE_DEBUG=true
