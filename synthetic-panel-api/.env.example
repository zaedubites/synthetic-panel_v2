# Synthetic Panel API Environment Variables

# App Settings
DEBUG=true
ENVIRONMENT=development

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/edubites
DATABASE_SCHEMA=synthetic_panel

# JWT Authentication (from auth-service)
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"
JWT_ALGORITHM=RS256

# External Services
AUTH_SERVICE_URL=http://localhost:8001
PLATFORM_API_URL=http://localhost:8000

# Azure OpenAI
AZURE_OPENAI_API_KEY=your_azure_openai_key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ElevenLabs (Voice)
ELEVENLABS_API_KEY=your_elevenlabs_key

# Replicate (Avatar Generation)
REPLICATE_API_KEY=your_replicate_token

# Supabase Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_key

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:3004","http://localhost:3001"]

# Sentry (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# WebSocket
WS_HEARTBEAT_INTERVAL=30
